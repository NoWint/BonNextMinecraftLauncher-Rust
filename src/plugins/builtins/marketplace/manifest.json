{
  "id": "com.bonnext.marketplace",
  "name": "Marketplace",
  "version": "1.0.0",
  "description": "Modrinth & CurseForge & ModpackIndex content browser, search, collections, and optimization presets",
  "author": "BonNext",
  "minAppVersion": "1.0.0",
  "dependencies": [],
  "permissions": [
    "http:modrinth.com",
    "http:curseforge.com",
    "http:modpackindex.com",
    "fs:read:instances",
    "fs:write:instances",
    "invoke:marketplace",
    "invoke:core:instances:read",
    "invoke:core:instances:write",
    "invoke:core:versions:read",
    "invoke:core:versions:write",
    "invoke:core:content:read",
    "invoke:core:content:write",
    "invoke:core:download",
    "events:listen",
    "events:emit"
  ],
  "i18n": {
    "en-US": {
      "sidebar.store": "Store",
      "sidebar.collections": "Collections",
      "sidebar.library": "Library"
    },
    "zh-CN": {
      "sidebar.store": "商店",
      "sidebar.collections": "我的收藏",
      "sidebar.library": "内容库"
    }
  },
  "contributes": {
    "routes": [
      { "path": "/store/:type/:slug", "component": "ContentDetailPage" }
    ],
    "sidebar": [],
    "settings": []
  }
}
